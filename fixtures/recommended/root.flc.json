    "endDate": "2010-12-31",
    "problem": {
      "topProblems": [
        {
          "id": "prob-unreliable-ride",
          "title": "Hard to find a clean, reliable, and affordable ride in a timely manner"
        },
        {
          "id": "prob-hail-friction",
          "title": "Street-hailing and phone dispatch are opaque — unknown ETA, cash hassle, no trip trail"
        },
        {
          "id": "prob-driver-idle",
          "title": "Drivers lack flexible demand and spend too much time idle or chasing radio dispatch"
        }
      ],
      "existingAlternatives": [
        {
          "id": "alt-taxis",
          "title": "Traditional taxis"
        },
        {
          "id": "alt-transit",
          "title": "Public transportation"
        },
        {
          "id": "alt-own-car",
          "title": "Rental cars / personal cars / walking"
        },
        {
          "id": "alt-other-hail",
          "title": "Other ride-hailing (later: Lyft and local clones)"
        }
      ]
    },
    "solution": {
      "features": [
        {
          "id": "feat-on-demand-dispatch",
          "title": "Mobile app that matches riders with nearby drivers in minutes"
        },
        {
          "id": "feat-cashless-pay",
          "title": "Cashless card payment with automatic receipts"
        },
        {
          "id": "feat-gps-ratings",
