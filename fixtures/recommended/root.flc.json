          "title": "Business travelers who want a professional, on-demand car"
        },
        {
          "id": "seg-nightlife",
          "title": "Night-out riders when transit is sparse or unreliable"
        }
      ],
      "earlyAdopters": [
        {
          "id": "adopt-sf-tech",
          "title": "Tech-savvy SF urbanites"
        },
        {
          "id": "adopt-taxi-unhappy",
          "title": "Frequent taxi users unhappy with service"
        },
        {
          "id": "adopt-nightlife",
          "title": "Event and nightlife crowds"
        }
      ]
