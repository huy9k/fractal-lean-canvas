            "every": 1,
            "unit": "month"
          }
        },
        {
          "id": "rev-surge",
          "title": "Surge pricing during peak demand",
          "amountMinor": 2000000,
          "cadence": {
            "type": "recurring",
            "every": 1,
            "unit": "month"
          }
        }
