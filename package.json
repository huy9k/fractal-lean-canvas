{
  "name": "fractal-lean-canvas",
  "version": "0.8.0",
  "description": "TypeBox schema, types, and validators for Fractal Lean Canvas (FLC)",
  "type": "module",
  "license": "MIT",
  "bin": {
    "fractal-lean-canvas": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test tests/**/*.test.ts",
    "validate": "tsx src/cli.ts validate fixtures/recommended"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^7.0.2"
  }
}
