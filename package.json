{
  "name": "fractal-lean-canvas",
  "version": "0.13.0",
  "description": "TypeBox schema, types, and validators for Fractal Lean Canvas (FLC)",
  "type": "module",
  "license": "MIT",
  "bin": {
    "fractal-lean-canvas": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "files": [
    "dist",
    ".agents/skills"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test tests/**/*.test.ts",
    "validate": "tsx src/cli/index.ts validate fixtures/recommended"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^7.0.2"
  }
}
